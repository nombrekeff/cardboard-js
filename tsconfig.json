{
  "compilerOptions": {
    "target": "ES6",
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "lib": ["dom", "ES2016"],
    "types": ["node", "jest"]
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["./dist", "./examples", "./tests"]
}
